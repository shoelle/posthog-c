# Live PostHog contract test credentials.
#
# Copy this file to .env (which is gitignored) and fill in your key, then run:
#   Windows:      pwsh scripts/live-contract.ps1
#   Linux/macOS:  ./scripts/live-contract.sh    (see the TLS note below)
#
# Use a DISPOSABLE PostHog project. POSTHOG_API_KEY is a write-only ingestion key
# (it can send events, not read your data), but treat it as a secret regardless.
#
# NOTE: real HTTPS delivery currently works on Windows only (WinHTTP). On
# Linux/macOS the TLS backends are stubbed, so point POSTHOG_HOST at a plaintext
# http:// reverse proxy until they land.

# --- required ---
# Your project API key - shown as "Project token" / "Project API key" in Project
# Settings, starts with phc_. NOT a personal API key (phx_).
POSTHOG_API_KEY=phc_your_disposable_project_key

# --- optional (defaults shown) ---
# POSTHOG_HOST=https://us.i.posthog.com
# POSTHOG_DISTINCT_ID=posthog-c-live-contract-install

# --- optional: verify a feature flag end-to-end (create the flag first) ---
# POSTHOG_FLAG_KEY=posthog-c-contract-flag
# POSTHOG_EXPECT_FLAG=true
# POSTHOG_EXPECT_PAYLOAD={"tier":"gold"}
